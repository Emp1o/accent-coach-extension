{
  "manifest_version": 3,
  "name": "ОрфоДракон: тренажёр ЕГЭ",
  "version": "2.1.0",
  "description": "Тренажёр по русскому языку для подготовки к ЕГЭ: ударения, пунктуация, карточки повторения, статистика, импорт словарей и игровой прогресс.",
  "permissions": [
    "contextMenus",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ОрфоДракон",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "homepage_url": "https://emp1o.github.io/accent-coach-site/",
  "short_name": "ОрфоДракон"
}