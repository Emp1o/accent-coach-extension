{
  "manifest_version": 3,
  "name": "Accent Coach for Russian",
  "version": "2.0.0",
  "description": "Показывает ударение по выделению, сохраняет слова, повторяет их и тренирует орфоэпию в формате flashcards. Локальная бесплатная версия без OpenAI.",
  "permissions": [
    "contextMenus",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Accent Coach for Russian",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}